{
    "annotations": {
        "list": [
            {
                "builtIn": 1,
                "datasource": {
                    "type": "grafana",
                    "uid": "-- Grafana --"
                },
                "enable": true,
                "hide": true,
                "iconColor": "rgba(0, 211, 255, 1)",
                "name": "Annotations & Alerts",
                "type": "dashboard"
            }
        ]
    },
    "editable": false,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "type": "stat",
            "title": "Target Health",
            "id": 1,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "up{job=~\"customer-service|product-service|order-service|payment-service|notification-service|gateway|prometheus\"}",
                    "legendFormat": "{{job}}",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto"
            },
            "fieldConfig": {
                "defaults": {
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "DOWN",
                                    "color": "red"
                                },
                                "1": {
                                    "text": "UP",
                                    "color": "green"
                                }
                            }
                        }
                    ]
                }
            }
        },
        {
            "type": "stat",
            "title": "Total Active Targets",
            "id": 2,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "sum(up)",
                    "refId": "A"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "HTTP Requests Rate",
            "id": 3,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 8
            },
            "targets": [
                {
                    "expr": "rate(http_requests_total[1m])",
                    "legendFormat": "{{method}} {{path}}",
                    "refId": "A"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "HTTP Latency (p95)",
            "id": 4,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 16
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
                    "refId": "A"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "DB Query Duration",
            "id": 5,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 24
            },
            "targets": [
                {
                    "expr": "rate(db_query_duration_seconds_sum[1m]) / rate(db_query_duration_seconds_count[1m])",
                    "refId": "A"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Kafka Messages Produced",
            "id": 6,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 32
            },
            "targets": [
                {
                    "expr": "rate(kafka_messages_produced_total[1m])",
                    "refId": "A"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Kafka Messages Consumed",
            "id": 7,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 32
            },
            "targets": [
                {
                    "expr": "rate(kafka_messages_consumed_total[1m])",
                    "refId": "A"
                }
            ]
        }
    ],
    "refresh": "5s",
    "schemaVersion": 39,
    "style": "dark",
    "tags": [
        "gocommercex"
    ],
    "templating": {
        "list": []
    },
    "time": {
        "from": "now-15m",
        "to": "now"
    },
    "timezone": "",
    "title": "GoCommerceX Overview",
    "version": 1
